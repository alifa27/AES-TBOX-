#ifndef INC_AES_TABLES_H_
#define INC_AES_TABLES_H_

#include <stdint.h>

// -----------------------------------------------------------------------------
// TABLES T-BOX CHIFFREMENT
// -----------------------------------------------------------------------------
extern const uint32_t T0[256];
extern const uint32_t T1[256];
extern const uint32_t T2[256];
extern const uint32_t T3[256];
extern const uint8_t SBOX[256];

// -----------------------------------------------------------------------------
// TABLES T-BOX DÉCHIFFREMENT (Ce qu'il manquait !)
// -----------------------------------------------------------------------------
extern const uint32_t InvT0[256];
extern const uint32_t InvT1[256];
extern const uint32_t InvT2[256];
extern const uint32_t InvT3[256];
extern const uint8_t INVSBOX[256];

// -----------------------------------------------------------------------------
// MACROS D'EXTRACTION D'OCTETS (Gestion de l'Endianness)
// -----------------------------------------------------------------------------
#define B0(x) ((uint8_t)((x) & 0xFF))           // Extrait l'octet 0 (bits 0-7)
#define B1(x) ((uint8_t)(((x) >> 8) & 0xFF))    // Extrait l'octet 1 (bits 8-15)
#define B2(x) ((uint8_t)(((x) >> 16) & 0xFF))   // Extrait l'octet 2 (bits 16-23)
#define B3(x) ((uint8_t)(((x) >> 24) & 0xFF))   // Extrait l'octet 3 (bits 24-31)

#endif /* INC_AES_TABLES_H_ */
