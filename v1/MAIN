/* USER CODE BEGIN PV */
// 1. Vecteur de test standard AES-128 (FIPS 197)
const uint8_t test_plaintext[16] = {0x00, 0x11, 0x22, 0x33, 0x44, 0x55, 0x66, 0x77,
                                    0x88, 0x99, 0xaa, 0xbb, 0xcc, 0xdd, 0xee, 0xff};

// 2. Clé étendue (Round Keys) pré-calculée pour la clé standard :
// 00 01 02 03 04 05 06 07 08 09 0a 0b 0c 0d 0e 0f
// Formatée en mots de 32 bits Little-Endian pour la V1.
const uint32_t test_roundKeys[44] = {
    0x03020100, 0x07060504, 0x0b0a0908, 0x0f0e0d0c,
    0xa0fafe17, 0xa7f4fbf3, 0xac7766f3, 0xa3796bcf,
    0xf2c295f2, 0x55366a01, 0xf9a10cf2, 0x5ad8673d,
    0x2b31122d, 0x7e07782c, 0x87a674de, 0xdd7e13e3,
    0x7120db72, 0x0f27a35e, 0x8881d780, 0x55ffc463,
    0xe13f0cc8, 0xee18af96, 0x66997816, 0x3366bc75,
    0xc4b7bd14, 0x2aaf1282, 0x4c366a94, 0x7f50d6e1,
    0xe7a5058c, 0xcd0a170e, 0x813c7d9a, 0xfe6cac7b,
    0xb01cdf2a, 0x7d16c824, 0xfc2ab5be, 0x024619c5,
    0xdb096e8d, 0xa61fa6a9, 0x5a351317, 0x58730ad2,
    0x4e06f5bc, 0xe8195315, 0xb22c4002, 0xea5f4ac0
};

// 3. Variables pour stocker les résultats et les temps d'exécution
uint8_t encrypted_output[16];
uint8_t decrypted_output[16]; // Stockera le résultat du déchiffrement
volatile uint32_t cycle_count_enc_v1 = 0; // Cycles pour le chiffrement
volatile uint32_t cycle_count_dec_v1 = 0; // Cycles pour le déchiffrement

// 4. Pointeurs DWT pour la mesure précise des cycles CPU
volatile uint32_t *DWT_CTRL   = (volatile uint32_t *)0xE0001000;
volatile uint32_t *DWT_CYCCNT = (volatile uint32_t *)0xE0001004;
volatile uint32_t *DEMCR      = (volatile uint32_t *)0xE000EDFC;
/* USER CODE END PV */

/* Private function prototypes -----------------------------------------------*/
void SystemClock_Config(void);
void PeriphCommonClock_Config(void);
static void MX_GPIO_Init(void);
/* USER CODE BEGIN PFP */
void AES128_Encrypt_TBox_V1(const uint8_t *in, uint8_t *out, const uint32_t *roundKeys);
void AES128_Decrypt_TBox_V1(const uint8_t *in, uint8_t *out, const uint32_t *roundKeys);
void DWT_Init(void);
/* USER CODE END PFP */

/* Private user code ---------------------------------------------------------*/
/* USER CODE BEGIN 0 */

// --- INITIALISATION DU COMPTEUR DE CYCLES (DWT) ---
void DWT_Init(void) {
    *DEMCR |= 0x01000000;     // Active le bloc Trace
    *DWT_CYCCNT = 0;          // Remet le compteur à zéro
    *DWT_CTRL |= 1;           // Active le compteur DWT
}

// --- FONCTION DE CHIFFREMENT AES-128 T-BOX V1 ---
void AES128_Encrypt_TBox_V1(const uint8_t *in, uint8_t *out, const uint32_t *roundKeys) {
    uint32_t s0, s1, s2, s3;
    uint32_t t0, t1, t2, t3;

    // Chargement de l'état (Little-Endian)
    s0 = ((uint32_t)in[3] << 24) | ((uint32_t)in[2] << 16) | ((uint32_t)in[1] << 8) | in[0];
    s1 = ((uint32_t)in[7] << 24) | ((uint32_t)in[6] << 16) | ((uint32_t)in[5] << 8) | in[4];
    s2 = ((uint32_t)in[11] << 24)| ((uint32_t)in[10] << 16)| ((uint32_t)in[9] << 8) | in[8];
    s3 = ((uint32_t)in[15] << 24)| ((uint32_t)in[14] << 16)| ((uint32_t)in[13] << 8)| in[12];

    // AddRoundKey (Round 0)
    s0 ^= roundKeys[0];
    s1 ^= roundKeys[1];
    s2 ^= roundKeys[2];
    s3 ^= roundKeys[3];

    // Rounds 1 à 9
    for (int r = 1; r < 10; r++) {
        t0 = T0[B0(s0)] ^ T1[B1(s1)] ^ T2[B2(s2)] ^ T3[B3(s3)] ^ roundKeys[r*4 + 0];
        t1 = T0[B0(s1)] ^ T1[B1(s2)] ^ T2[B2(s3)] ^ T3[B3(s0)] ^ roundKeys[r*4 + 1];
        t2 = T0[B0(s2)] ^ T1[B1(s3)] ^ T2[B2(s0)] ^ T3[B3(s1)] ^ roundKeys[r*4 + 2];
        t3 = T0[B0(s3)] ^ T1[B1(s0)] ^ T2[B2(s1)] ^ T3[B3(s2)] ^ roundKeys[r*4 + 3];

        s0 = t0; s1 = t1; s2 = t2; s3 = t3;
    }

    // Round 10 (Pas de MixColumns, utilisation de la SBOX)
    t0 = ((uint32_t)SBOX[B0(s0)])       | ((uint32_t)SBOX[B1(s1)] << 8)  |
         ((uint32_t)SBOX[B2(s2)] << 16) | ((uint32_t)SBOX[B3(s3)] << 24);
    t0 ^= roundKeys[40];

    t1 = ((uint32_t)SBOX[B0(s1)])       | ((uint32_t)SBOX[B1(s2)] << 8)  |
         ((uint32_t)SBOX[B2(s3)] << 16) | ((uint32_t)SBOX[B3(s0)] << 24);
    t1 ^= roundKeys[41];

    t2 = ((uint32_t)SBOX[B0(s2)])       | ((uint32_t)SBOX[B1(s3)] << 8)  |
         ((uint32_t)SBOX[B2(s0)] << 16) | ((uint32_t)SBOX[B3(s1)] << 24);
    t2 ^= roundKeys[42];

    t3 = ((uint32_t)SBOX[B0(s3)])       | ((uint32_t)SBOX[B1(s0)] << 8)  |
         ((uint32_t)SBOX[B2(s1)] << 16) | ((uint32_t)SBOX[B3(s2)] << 24);
    t3 ^= roundKeys[43];

    // Sauvegarde en sortie (Little-Endian)
    out[0]  = (uint8_t)(t0);       out[1]  = (uint8_t)(t0 >> 8);
    out[2]  = (uint8_t)(t0 >> 16); out[3]  = (uint8_t)(t0 >> 24);

    out[4]  = (uint8_t)(t1);       out[5]  = (uint8_t)(t1 >> 8);
    out[6]  = (uint8_t)(t1 >> 16); out[7]  = (uint8_t)(t1 >> 24);

    out[8]  = (uint8_t)(t2);       out[9]  = (uint8_t)(t2 >> 8);
    out[10] = (uint8_t)(t2 >> 16); out[11] = (uint8_t)(t2 >> 24);

    out[12] = (uint8_t)(t3);       out[13] = (uint8_t)(t3 >> 8);
    out[14] = (uint8_t)(t3 >> 16); out[15] = (uint8_t)(t3 >> 24);
}

// --- FONCTION DE DECHIFFREMENT AES-128 T-BOX V1 ---
void AES128_Decrypt_TBox_V1(const uint8_t *in, uint8_t *out, const uint32_t *roundKeys) {
    uint32_t s0, s1, s2, s3;
    uint32_t t0, t1, t2, t3;

    // 1. Chargement du Ciphertext
    s0 = ((uint32_t)in[3] << 24) | ((uint32_t)in[2] << 16) | ((uint32_t)in[1] << 8) | in[0];
    s1 = ((uint32_t)in[7] << 24) | ((uint32_t)in[6] << 16) | ((uint32_t)in[5] << 8) | in[4];
    s2 = ((uint32_t)in[11] << 24)| ((uint32_t)in[10] << 16)| ((uint32_t)in[9] << 8) | in[8];
    s3 = ((uint32_t)in[15] << 24)| ((uint32_t)in[14] << 16)| ((uint32_t)in[13] << 8)| in[12];

    // 2. AddRoundKey initial (On utilise la DERNIÈRE clé du round 10)
    s0 ^= roundKeys[40]; s1 ^= roundKeys[41]; s2 ^= roundKeys[42]; s3 ^= roundKeys[43];

    // 3. Rounds 9 à 1 (Inverses)
    for (int r = 9; r >= 1; r--) {
        // Attention : InvShiftRows change l'ordre des octets !
        t0 = InvT0[B0(s0)] ^ InvT1[B1(s3)] ^ InvT2[B2(s2)] ^ InvT3[B3(s1)] ^ roundKeys[r*4 + 0];
        t1 = InvT0[B0(s1)] ^ InvT1[B1(s0)] ^ InvT2[B2(s3)] ^ InvT3[B3(s2)] ^ roundKeys[r*4 + 1];
        t2 = InvT0[B0(s2)] ^ InvT1[B1(s1)] ^ InvT2[B2(s0)] ^ InvT3[B3(s3)] ^ roundKeys[r*4 + 2];
        t3 = InvT0[B0(s3)] ^ InvT1[B1(s2)] ^ InvT2[B2(s1)] ^ InvT3[B3(s0)] ^ roundKeys[r*4 + 3];

        s0 = t0; s1 = t1; s2 = t2; s3 = t3;
    }

    // 4. Round Final (Round 0 - Utilisation de INVSBOX)
    t0 = ((uint32_t)INVSBOX[B0(s0)])       | ((uint32_t)INVSBOX[B1(s3)] << 8)  |
         ((uint32_t)INVSBOX[B2(s2)] << 16) | ((uint32_t)INVSBOX[B3(s1)] << 24);
    t0 ^= roundKeys[0];

    t1 = ((uint32_t)INVSBOX[B0(s1)])       | ((uint32_t)INVSBOX[B1(s0)] << 8)  |
         ((uint32_t)INVSBOX[B2(s3)] << 16) | ((uint32_t)INVSBOX[B3(s2)] << 24);
    t1 ^= roundKeys[1];

    t2 = ((uint32_t)INVSBOX[B0(s2)])       | ((uint32_t)INVSBOX[B1(s1)] << 8)  |
         ((uint32_t)INVSBOX[B2(s0)] << 16) | ((uint32_t)INVSBOX[B3(s3)] << 24);
    t2 ^= roundKeys[2];

    t3 = ((uint32_t)INVSBOX[B0(s3)])       | ((uint32_t)INVSBOX[B1(s2)] << 8)  |
         ((uint32_t)INVSBOX[B2(s1)] << 16) | ((uint32_t)INVSBOX[B3(s0)] << 24);
    t3 ^= roundKeys[3];

    // 5. Sortie finale
    out[0]  = (uint8_t)(t0);       out[1]  = (uint8_t)(t0 >> 8);
    out[2]  = (uint8_t)(t0 >> 16); out[3]  = (uint8_t)(t0 >> 24);

    out[4]  = (uint8_t)(t1);       out[5]  = (uint8_t)(t1 >> 8);
    out[6]  = (uint8_t)(t1 >> 16); out[7]  = (uint8_t)(t1 >> 24);

    out[8]  = (uint8_t)(t2);       out[9]  = (uint8_t)(t2 >> 8);
    out[10] = (uint8_t)(t2 >> 16); out[11] = (uint8_t)(t2 >> 24);

    out[12] = (uint8_t)(t3);       out[13] = (uint8_t)(t3 >> 8);
    out[14] = (uint8_t)(t3 >> 16); out[15] = (uint8_t)(t3 >> 24);
}
/* USER CODE END 0 */

/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{

  /* USER CODE BEGIN 1 */

  /* USER CODE END 1 */

  /* MCU Configuration--------------------------------------------------------*/

  /* Reset of all peripherals, Initializes the Flash interface and the Systick. */
  HAL_Init();

  /* USER CODE BEGIN Init */

  /* USER CODE END Init */

  /* Configure the system clock */
  SystemClock_Config();

  /* Configure the peripherals common clocks */
  PeriphCommonClock_Config();

  /* USER CODE BEGIN SysInit */

  /* USER CODE END SysInit */

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  /* USER CODE BEGIN 2 */

  // Initialisation du compteur de cycles CPU
  DWT_Init();

  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
      // --- MESURE DU CHIFFREMENT ---
      __disable_irq();
      uint32_t start_enc = *DWT_CYCCNT;

      // Chiffrement : Plaintext -> Encrypted_output
      AES128_Encrypt_TBox_V1(test_plaintext, encrypted_output, test_roundKeys);

      uint32_t end_enc = *DWT_CYCCNT;
      __enable_irq();
      cycle_count_enc_v1 = end_enc - start_enc;

      // --- MESURE DU DECHIFFREMENT ---
      __disable_irq();
      uint32_t start_dec = *DWT_CYCCNT;

      // Déchiffrement : Encrypted_output -> Decrypted_output
      AES128_Decrypt_TBox_V1(encrypted_output, decrypted_output, test_roundKeys);

      uint32_t end_dec = *DWT_CYCCNT;
      __enable_irq();
      cycle_count_dec_v1 = end_dec - start_dec;

      // Clignotement de la LED1
      HAL_GPIO_TogglePin(GPIOB, LD1_Pin);

      // Attente avant la prochaine exécution
      HAL_Delay(500);

    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

/**
  * @brief System Clock Configuration
  * @retval None
  */
void SystemClock_Config(void)
{
  RCC_OscInitTypeDef RCC_OscInitStruct = {0};
  RCC_ClkInitTypeDef RCC_ClkInitStruct = {0};

  /** Configure the main internal regulator output voltage
  */
  __HAL_PWR_VOLTAGESCALING_CONFIG(PWR_REGULATOR_VOLTAGE_SCALE1);

  /** Initializes the RCC Oscillators according to the specified parameters
  * in the RCC_OscInitTypeDef structure.
  */
  RCC_OscInitStruct.OscillatorType = RCC_OSCILLATORTYPE_HSI|RCC_OSCILLATORTYPE_MSI;
  RCC_OscInitStruct.HSIState = RCC_HSI_ON;
  RCC_OscInitStruct.MSIState = RCC_MSI_ON;
  RCC_OscInitStruct.HSICalibrationValue = RCC_HSICALIBRATION_DEFAULT;
  RCC_OscInitStruct.MSICalibrationValue = RCC_MSICALIBRATION_DEFAULT;
  RCC_OscInitStruct.MSIClockRange = RCC_MSIRANGE_10;
  RCC_OscInitStruct.PLL.PLLState = RCC_PLL_NONE;
  if (HAL_RCC_OscConfig(&RCC_OscInitStruct) != HAL_OK)
  {
    Error_Handler();
  }

  /** Configure the SYSCLKSource, HCLK, PCLK1 and PCLK2 clocks dividers
  */
  RCC_ClkInitStruct.ClockType = RCC_CLOCKTYPE_HCLK4|RCC_CLOCKTYPE_HCLK2
                              |RCC_CLOCKTYPE_HCLK|RCC_CLOCKTYPE_SYSCLK
                              |RCC_CLOCKTYPE_PCLK1|RCC_CLOCKTYPE_PCLK2;
  RCC_ClkInitStruct.SYSCLKSource = RCC_SYSCLKSOURCE_MSI;
  RCC_ClkInitStruct.AHBCLKDivider = RCC_SYSCLK_DIV1;
  RCC_ClkInitStruct.APB1CLKDivider = RCC_HCLK_DIV1;
  RCC_ClkInitStruct.APB2CLKDivider = RCC_HCLK_DIV1;
  RCC_ClkInitStruct.AHBCLK2Divider = RCC_SYSCLK_DIV1;
  RCC_ClkInitStruct.AHBCLK4Divider = RCC_SYSCLK_DIV1;

  if (HAL_RCC_ClockConfig(&RCC_ClkInitStruct, FLASH_LATENCY_1) != HAL_OK)
  {
    Error_Handler();
  }
}

/**
  * @brief Peripherals Common Clock Configuration
  * @retval None
  */
void PeriphCommonClock_Config(void)
{
  RCC_PeriphCLKInitTypeDef PeriphClkInitStruct = {0};

  /** Initializes the peripherals clock
  */
  PeriphClkInitStruct.PeriphClockSelection = RCC_PERIPHCLK_SMPS;
  PeriphClkInitStruct.SmpsClockSelection = RCC_SMPSCLKSOURCE_HSI;
  PeriphClkInitStruct.SmpsDivSelection = RCC_SMPSCLKDIV_RANGE0;

  if (HAL_RCCEx_PeriphCLKConfig(&PeriphClkInitStruct) != HAL_OK)
  {
    Error_Handler();
  }
  /* USER CODE BEGIN Smps */

  /* USER CODE END Smps */
}

/**
  * @brief GPIO Initialization Function
  * @param None
  * @retval None
  */
static void MX_GPIO_Init(void)
{
  GPIO_InitTypeDef GPIO_InitStruct = {0};
  /* USER CODE BEGIN MX_GPIO_Init_1 */

  /* USER CODE END MX_GPIO_Init_1 */

  /* GPIO Ports Clock Enable */
  __HAL_RCC_GPIOC_CLK_ENABLE();
  __HAL_RCC_GPIOB_CLK_ENABLE();
  __HAL_RCC_GPIOA_CLK_ENABLE();
  __HAL_RCC_GPIOD_CLK_ENABLE();

  /*Configure GPIO pin Output Level */
  HAL_GPIO_WritePin(GPIOB, LD2_Pin|LD3_Pin|LD1_Pin, GPIO_PIN_RESET);

  /*Configure GPIO pin : B1_Pin */
  GPIO_InitStruct.Pin = B1_Pin;
  GPIO_InitStruct.Mode = GPIO_MODE_INPUT;
  GPIO_InitStruct.Pull = GPIO_NOPULL;
  HAL_GPIO_Init(B1_GPIO_Port, &GPIO_InitStruct);

  /*Configure GPIO pins : LD2_Pin LD3_Pin LD1_Pin */
  GPIO_InitStruct.Pin = LD2_Pin|LD3_Pin|LD1_Pin;
  GPIO_InitStruct.Mode = GPIO_MODE_OUTPUT_PP;
  GPIO_InitStruct.Pull = GPIO_NOPULL;
  GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_LOW;
  HAL_GPIO_Init(GPIOB, &GPIO_InitStruct);

  /*Configure GPIO pins : USB_DM_Pin USB_DP_Pin */
  GPIO_InitStruct.Pin = USB_DM_Pin|USB_DP_Pin;
  GPIO_InitStruct.Mode = GPIO_MODE_AF_PP;
  GPIO_InitStruct.Pull = GPIO_NOPULL;
  GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_LOW;
  GPIO_InitStruct.Alternate = GPIO_AF10_USB;
  HAL_GPIO_Init(GPIOA, &GPIO_InitStruct);

  /*Configure GPIO pins : B2_Pin B3_Pin */
  GPIO_InitStruct.Pin = B2_Pin|B3_Pin;
  GPIO_InitStruct.Mode = GPIO_MODE_INPUT;
  GPIO_InitStruct.Pull = GPIO_NOPULL;
  HAL_GPIO_Init(GPIOD, &GPIO_InitStruct);

  /*Configure GPIO pins : STLINK_RX_Pin STLINK_TX_Pin */
  GPIO_InitStruct.Pin = STLINK_RX_Pin|STLINK_TX_Pin;
  GPIO_InitStruct.Mode = GPIO_MODE_AF_PP;
  GPIO_InitStruct.Pull = GPIO_NOPULL;
  GPIO_InitStruct.Speed = GPIO_SPEED_FREQ_LOW;
  GPIO_InitStruct.Alternate = GPIO_AF7_USART1;
  HAL_GPIO_Init(GPIOB, &GPIO_InitStruct);

  /* USER CODE BEGIN MX_GPIO_Init_2 */

  /* USER CODE END MX_GPIO_Init_2 */
}

